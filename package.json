{
  "name": "mandios-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev frontend",
    "build": "next build frontend",
    "start": "next start frontend",
    "lint": "node ./node_modules/eslint/bin/eslint.js frontend --ext .js,.jsx,.ts,.tsx",
    "build:mobile": "cd frontend && bash scripts/build-mobile.sh",
    "cap:sync": "cd frontend && npx cap sync",
    "open:ios": "cd frontend && npx cap open ios",
    "open:android": "cd frontend && npx cap open android",
    "open:live": "NEXT_PUBLIC_CAPACITOR=true npx next dev frontend & sleep 4 && cd frontend && npx cap run ios --livereload --external",
    "security:check": "npm audit --omit=dev --audit-level=critical",
    "security:check:all": "npm audit --omit=dev",
    "typecheck": "node ./node_modules/typescript/lib/_tsc.js --noEmit",
    "predeploy": "npm run security:check && npm run lint && npm run typecheck"
  },
  "dependencies": {
