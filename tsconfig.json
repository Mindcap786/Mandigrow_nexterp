{
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "incremental": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "zod": [
        "node_modules/zod"
      ],
      "@/*": [
        "./frontend/*"
      ]
    },
    "target": "ES2017"
  },
  "include": [
    "frontend/next-env.d.ts",
    "frontend/.next/types/**/*.ts",
    "frontend/**/*.ts",
    "frontend/**/*.tsx",
    "/tmp/mandipro-next/types/**/*.ts",
    "/tmp/mandipro-next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "tmp",
    "out"
  ]
}
