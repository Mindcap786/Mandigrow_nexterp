2f:["$","details","Is MandiGrow available in Hindi and regional languages?",{"className":"group bg-white border border-emerald-100 rounded-3xl p-6 shadow-sm open:shadow-md transition","open":false,"children":[["$","summary",null,{"className":"cursor-pointer text-lg font-black tracking-tight list-none flex items-start justify-between gap-4","children":[["$","span",null,{"children":"Is MandiGrow available in Hindi and regional languages?"}],["$","span",null,{"className":"text-emerald-600 text-2xl leading-none group-open:rotate-45 transition-transform","children":"+"}]]}],["$","p",null,{"className":"text-gray-700 mt-4 leading-relaxed","children":"Yes. MandiGrow is fully multilingual and supports Hindi, English, Tamil, Telugu, Kannada, Malayalam and Urdu. The entire app, bills, prints and reports are available in every supported language. Switch with one tap."}]]}]
30:["$","details","Does MandiGrow work as a mandi khata software?",{"className":"group bg-white border border-emerald-100 rounded-3xl p-6 shadow-sm open:shadow-md transition","open":false,"children":[["$","summary",null,{"className":"cursor-pointer text-lg font-black tracking-tight list-none flex items-start justify-between gap-4","children":[["$","span",null,{"children":"Does MandiGrow work as a mandi khata software?"}],["$","span",null,{"className":"text-emerald-600 text-2xl leading-none group-open:rotate-45 transition-transform","children":"+"}]]}],["$","p",null,{"className":"text-gray-700 mt-4 leading-relaxed","children":"Yes. MandiGrow is a modern mandi khata software that replaces paper bahis with a fast, mobile-friendly digital khata. Track party balances, advances, payments and credits in real time."}]]}]
31:["$","details","Can I use MandiGrow on a mobile phone?",{"className":"group bg-white border border-emerald-100 rounded-3xl p-6 shadow-sm open:shadow-md transition","open":false,"children":[["$","summary",null,{"className":"cursor-pointer text-lg font-black tracking-tight list-none flex items-start justify-between gap-4","children":[["$","span",null,{"children":"Can I use MandiGrow on a mobile phone?"}],["$","span",null,{"className":"text-emerald-600 text-2xl leading-none group-open:rotate-45 transition-transform","children":"+"}]]}],["$","p",null,{"className":"text-gray-700 mt-4 leading-relaxed","children":"Yes. MandiGrow runs on Android phones and on the desktop web — using the same account and the same data. You can take orders at the mandi gate and review reports from home."}]]}]
