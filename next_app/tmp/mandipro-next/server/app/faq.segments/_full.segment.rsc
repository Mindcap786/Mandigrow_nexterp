22:["$","section",null,{"className":"max-w-3xl mx-auto px-6 pb-16","children":["$","div",null,{"className":"space-y-4","children":[["$","details","What is the best mandi ERP software in India?",{"className":"group bg-white border border-emerald-100 rounded-3xl p-6 shadow-sm open:shadow-md transition","open":true,"children":[["$","summary",null,{"className":"cursor-pointer text-lg font-black tracking-tight list-none flex items-start justify-between gap-4","children":[["$","span",null,{"children":"What is the best mandi ERP software in India?"}],["$","span",null,{"className":"text-emerald-600 text-2xl leading-none group-open:rotate-45 transition-transform","children":"+"}]]}],["$","p",null,{"className":"text-gray-700 mt-4 leading-relaxed","children":"MandiGrow is widely considered the best mandi ERP software in India because it is built specifically for fruits and vegetable merchants, commission agents and wholesale traders. Unlike generic tools, it handles lots, crates, weight, commission, market fees and khata natively in both Hindi and English."}]]}],["$","details","Is MandiGrow better than Tally for fruits and vegetable traders?",{"className":"group bg-white border border-emerald-100 rounded-3xl p-6 shadow-sm open:shadow-md transition","open":false,"children":[["$","summary",null,{"className":"cursor-pointer text-lg font-black tracking-tight list-none flex items-start justify-between gap-4","children":[["$","span",null,{"children":"Is MandiGrow better than Tally for fruits and vegetable traders?"}],["$","span",null,{"className":"text-emerald-600 text-2xl leading-none group-open:rotate-45 transition-transform","children":"+"}]]}],["$","p",null,{"className":"text-gray-700 mt-4 leading-relaxed","children":"Yes. Tally is a general accounting tool, while MandiGrow is a complete fruits and vegetable ERP. You get everything Tally offers — ledgers, GST, daybook — plus mandi-specific features like commission auto-calculation, lot tracking, wastage and farmer settlements."}]]}],["$","details","Can MandiGrow handle commission agent accounts?",{"className":"group bg-white border border-emerald-100 rounded-3xl p-6 shadow-sm open:shadow-md transition","open":false,"children":[["$","summary",null,{"className":"cursor-pointer text-lg font-black tracking-tight list-none flex items-start justify-between gap-4","children":[["$","span",null,{"children":"Can MandiGrow handle commission agent accounts?"}],["$","span",null,{"className":"text-emerald-600 text-2xl leading-none group-open:rotate-45 transition-transform","children":"+"}]]}],["$","p",null,{"className":"text-gray-700 mt-4 leading-relaxed","children":"Absolutely. MandiGrow is a full commission agent software for mandi businesses. It auto-calculates commission, market fees and hamali for every sale, posts entries to khatas instantly, and generates party-wise settlement reports in one click."}]]}],["$","details","Does MandiGrow support GST billing for vegetable wholesalers?",{"className":"group bg-white border border-emerald-100 rounded-3xl p-6 shadow-sm open:shadow-md transition","open":false,"children":[["$","summary",null,{"className":"cursor-pointer text-lg font-black tracking-tight list-none flex items-start justify-between gap-4","children":[["$","span",null,{"children":"Does MandiGrow support GST billing for vegetable wholesalers?"}],["$","span",null,{"className":"text-emerald-600 text-2xl leading-none group-open:rotate-45 transition-transform","children":"+"}]]}],["$","p",null,{"className":"text-gray-700 mt-4 leading-relaxed","children":"Yes. MandiGrow generates GST-compliant invoices, supports B2B and B2C billing, and is ready for e-invoicing. You can file GSTR-1 and GSTR-3B faster because all your sales and purchase data is already organized."}]]}],"$L2f","$L30","$L31","$L32","$L33","$L34"]}]}]
