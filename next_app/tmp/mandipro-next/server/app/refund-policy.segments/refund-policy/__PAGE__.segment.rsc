17:["$","p",null,{"className":"text-gray-700 leading-relaxed mb-6","children":"MandiGrow reserves the right to modify this Refund Policy at any time. Any changes will be effective immediately upon posting to this page. Subscriptions active at the time of a policy change will be governed by the policy in effect at the start of their current billing cycle."}]
