14:["$","p",null,{"className":"text-gray-700 leading-relaxed mb-6","children":["If you believe you are eligible for a refund under this policy, please email us at ",["$","a",null,{"href":"mailto:billing@mandigrow.com","className":"text-emerald-700 font-bold hover:underline","children":"billing@mandigrow.com"}]," with your account details, transaction receipt, and the reason for the request."]}]
15:["$","p",null,{"className":"text-gray-700 leading-relaxed mb-6","children":["Approved refunds are processed to the original payment method (Credit Card, UPI, Bank Account) within ",["$","strong",null,{"children":"7-10 business days"}],", depending on your bank's processing times. We cannot issue refunds to alternate payment methods."]}]
