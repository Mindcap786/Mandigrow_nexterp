22:["$","p",null,{"className":"text-gray-700 leading-relaxed mb-6","children":["MandiGrow is a Business-to-Business (B2B) Software-as-a-Service (SaaS) platform. Because you receive instant, full access to our proprietary tools, reporting, and features upon payment, our general policy is that ",["$","strong",null,{"children":"all payments are non-refundable"}]," unless explicitly stated otherwise in this policy."]}]
23:["$","h2",null,{"className":"text-2xl font-black text-gray-900 mt-8 mb-3","children":"2. Monthly Subscriptions"}]
24:["$","p",null,{"className":"text-gray-700 leading-relaxed mb-6","children":"Payments for monthly subscriptions are strictly non-refundable. You may cancel your monthly subscription at any time, and you will retain access to your MandiGrow workspace until the end of your currently paid monthly billing cycle. We do not provide prorated refunds or credits for partial months of service."}]
25:["$","h2",null,{"className":"text-2xl font-black text-gray-900 mt-8 mb-3","children":"3. Annual Subscriptions (7-Day Guarantee)"}]
26:["$","p",null,{"className":"text-gray-700 leading-relaxed mb-3","children":["We understand that committing to an annual plan is a big decision for your business. Therefore, we offer a ",["$","strong",null,{"children":"7-Day Money-Back Guarantee"}]," exclusively on your ",["$","strong",null,{"children":"first"}]," annual subscription purchase."]}]
27:["$","ul",null,{"className":"list-disc pl-6 text-gray-700 space-y-2 mb-6","children":[["$","li",null,{"children":"If you decide MandiGrow is not right for you within the first seven (7) days of your initial annual subscription payment, you may request a full refund."}],["$","li",null,{"children":"Refund requests must be submitted in writing to our billing team within the 7-day window."}],["$","li",null,{"children":"This guarantee applies only to new, first-time annual subscriptions and does not apply to annual renewals."}],["$","li",null,{"children":"After the 7-day window has passed, the annual subscription fee becomes completely non-refundable, and you may only cancel the upcoming renewal."}]]}]
28:["$","h2",null,{"className":"text-2xl font-black text-gray-900 mt-8 mb-3","children":"4. Cancellations & Renewals"}]
29:["$","p",null,{"className":"text-gray-700 leading-relaxed mb-6","children":["Your MandiGrow subscription will automatically renew at the end of each billing cycle (monthly or annually) unless you cancel. It is your responsibility to cancel your subscription prior to the renewal date to avoid future charges. You can cancel directly from your account settings or by contacting support. ",["$","strong",null,{"children":"Forgetting to cancel does not entitle you to a refund for the subsequent billing cycle."}]]}]
2a:["$","h2",null,{"className":"text-2xl font-black text-gray-900 mt-8 mb-3","children":"5. Exceptions & Special Circumstances"}]
2b:["$","p",null,{"className":"text-gray-700 leading-relaxed mb-3","children":"We may process refunds or credit notes at our sole discretion in the following limited situations:"}]
2c:["$","ul",null,{"className":"list-disc pl-6 text-gray-700 space-y-2 mb-6","children":[["$","li",null,{"children":[["$","strong",null,{"children":"Duplicate Charges:"}]," If a technical error causes you to be charged multiple times for the same transaction."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Prolonged Outages:"}]," If MandiGrow suffers a severe, prolonged system-wide failure that prevents access to the core service for an extended period, violating our Terms of Service SLAs."]}]]}]
2d:["$","h2",null,{"className":"text-2xl font-black text-gray-900 mt-8 mb-3","children":"6. Non-Refundable Items"}]
2e:["$","p",null,{"className":"text-gray-700 leading-relaxed mb-3","children":"The following purchases and fees are strictly non-refundable under any circumstances:"}]
2f:["$","ul",null,{"className":"list-disc pl-6 text-gray-700 space-y-2 mb-6","children":[["$","li",null,{"children":"One-time setup, onboarding, or data migration fees."}],["$","li",null,{"children":"Custom development or custom integration charges."}],["$","li",null,{"children":"Third-party gateway fees, SMS gateway fees, or hardware costs."}],["$","li",null,{"children":"Taxes remitted to the government (such as GST)."}]]}]
