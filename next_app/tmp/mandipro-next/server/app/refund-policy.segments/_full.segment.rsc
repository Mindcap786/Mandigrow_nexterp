31:["$","p",null,{"className":"text-gray-700 leading-relaxed mb-6","children":["If you believe you are eligible for a refund under this policy, please email us at ",["$","a",null,{"href":"mailto:billing@mandigrow.com","className":"text-emerald-700 font-bold hover:underline","children":"billing@mandigrow.com"}]," with your account details, transaction receipt, and the reason for the request."]}]
32:["$","p",null,{"className":"text-gray-700 leading-relaxed mb-6","children":["Approved refunds are processed to the original payment method (Credit Card, UPI, Bank Account) within ",["$","strong",null,{"children":"7-10 business days"}],", depending on your bank's processing times. We cannot issue refunds to alternate payment methods."]}]
33:["$","h2",null,{"className":"text-2xl font-black text-gray-900 mt-8 mb-3","children":"8. Changes to this Policy"}]
34:["$","p",null,{"className":"text-gray-700 leading-relaxed mb-6","children":"MandiGrow reserves the right to modify this Refund Policy at any time. Any changes will be effective immediately upon posting to this page. Subscriptions active at the time of a policy change will be governed by the policy in effect at the start of their current billing cycle."}]
