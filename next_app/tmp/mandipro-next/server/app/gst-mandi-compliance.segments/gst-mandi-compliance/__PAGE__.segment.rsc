3:T963,{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Do commission agents in mandi need to file GST?","acceptedAnswer":{"@type":"Answer","text":"Yes. Commission agents whose turnover exceeds ₹20 lakhs (₹10 lakhs in special category states) must register for GST. MandiGrow auto-calculates GST on every commission sale and generates GSTR-1 ready data for filing, making compliance effortless."}},{"@type":"Question","name":"What is Mandi Tax (Cess) and which states have it?","acceptedAnswer":{"@type":"Answer","text":"Mandi Tax or Mandi Cess is a local levy charged on agricultural produce sold through APMC markets. It is separate from GST. States like Andhra Pradesh, Telangana, Maharashtra, Punjab, and Madhya Pradesh levy Mandi Tax. MandiGrow auto-calculates Mandi Cess based on the state your mandi operates in."}},{"@type":"Question","name":"Can MandiGrow generate GSTR-1 data for mandi traders?","acceptedAnswer":{"@type":"Answer","text":"Yes. MandiGrow automatically organizes all your sales data into GSTR-1 format — B2B (buyer-wise), B2C, and export records. Export ready for your CA or upload directly to the GST portal. No manual data entry, no spreadsheets."}},{"@type":"Question","name":"Is MandiGrow compliant with APMC regulations?","acceptedAnswer":{"@type":"Answer","text":"Yes. MandiGrow is designed for APMC-registered mandis and commission agents. It supports the mandatory documentation — gate entries, lot records, commission pattis, and trade statements — required by APMC authorities in most states."}},{"@type":"Question","name":"Does MandiGrow work for both registered and composition scheme dealers?","acceptedAnswer":{"@type":"Answer","text":"Yes. MandiGrow supports both regular GST registration and the Composition Scheme. For composition dealers, it tracks turnover thresholds and generates the simplified CMP-08 quarterly return data. Switch between tax modes without losing any transaction history."}},{"@type":"Question","name":"How does MandiGrow handle GST for different fruit and vegetable varieties?","acceptedAnswer":{"@type":"Answer","text":"Most fresh fruits and vegetables are exempt from GST under Chapter 7 of the HSN code. However, processed, branded, or packed produce may attract 5% or 12% GST. MandiGrow lets you configure HSN codes and GST rates per item — and auto-applies them on every invoice."}}]}0:{"rsc":["$","$1","c",{"children":[["$","main",null,{"className":"min-h-screen bg-[#f7fbf3] text-gray-900 pt-20","children":[["$","$L2",null,{}],["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$3"}}],["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Home\",\"item\":\"https://www.mandigrow.com\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"GST Mandi Compliance\",\"item\":\"https://www.mandigrow.com/gst-mandi-compliance\"}]}"}}],["$","section",null,{"className":"max-w-5xl mx-auto px-6 pt-16 pb-16","children":[["$","p",null,{"className":"text-emerald-700 font-black uppercase tracking-widest text-xs mb-4","children":"GST & Mandi Tax Compliance Software · India"}],["$","h1",null,{"className":"text-5xl md:text-6xl font-black tracking-tighter leading-[1.05] mb-6","children":["$","$L4",null,{"tKey":"seo_pages.gst_h1","fallback":"GST & Mandi Tax Compliance Software for Commission Agents in India"}]}],"$L5","$L6","$L7"]}],"$L8","$L9","$La","$Lb","$Lc","$Ld"]}],["$Le","$Lf","$L10"],"$L11"]}],"isPartial":false,"staleTime":300,"varyParams":null,"buildId":"Cjd_nGwxyej2TbsdiLf8Y"}
