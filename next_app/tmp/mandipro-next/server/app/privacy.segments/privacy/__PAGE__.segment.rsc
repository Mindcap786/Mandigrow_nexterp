25:["$","h2",null,{"className":"text-2xl font-black text-gray-900 mt-8 mb-3","children":"13. Changes to this Policy"}]
26:["$","p",null,{"className":"text-gray-700 leading-relaxed mb-0","children":"We may update this Privacy Policy from time to time. Material changes will be notified by email or in-app notice at least 7 days before they take effect. Your continued use of the Service after the effective date constitutes acceptance of the revised Policy."}]
