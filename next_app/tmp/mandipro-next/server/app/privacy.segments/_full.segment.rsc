20:["$","h2",null,{"className":"text-2xl font-black text-gray-900 mt-0 mb-3","children":"1. Introduction"}]
21:["$","p",null,{"className":"text-gray-700 leading-relaxed mb-6","children":"MINDT Private Limited (\"MandiGrow\", \"we\", \"us\", or \"our\") operates the MandiGrow SaaS platform (the \"Service\"), a mandi ERP solution for fruits & vegetable commission agents, wholesalers and traders across India. This Privacy Policy explains what information we collect, why we collect it, how we use it, and the rights you have over your data."}]
22:["$","p",null,{"className":"text-gray-700 leading-relaxed mb-6","children":"This Policy is issued under the Information Technology Act, 2000, the Information Technology (Reasonable Security Practices and Procedures and Sensitive Personal Data or Information) Rules, 2011, and the Digital Personal Data Protection Act, 2023 (\"DPDP Act\"). It is also designed to be GDPR-aware for users who interact with us from outside India."}]
23:["$","h2",null,{"className":"text-2xl font-black text-gray-900 mt-8 mb-3","children":"2. Information We Collect"}]
24:["$","p",null,{"className":"text-gray-700 leading-relaxed mb-3","children":[["$","strong",null,{"children":"2.1 Account & identity data:"}]," name, mobile number, email, business name, GSTIN, PAN, address, state, and login credentials."]}]
25:["$","p",null,{"className":"text-gray-700 leading-relaxed mb-3","children":[["$","strong",null,{"children":"2.2 Business & transactional data:"}]," sales invoices, purchase bills, daybook entries, ledgers, commission agent accounts, mandi khata records, party details, stock movement, inventory, and payment records."]}]
26:["$","p",null,{"className":"text-gray-700 leading-relaxed mb-3","children":[["$","strong",null,{"children":"2.3 GST & financial data:"}]," GST returns, HSN codes, tax computations, e-invoice data, and related fiscal records — classified as Sensitive Personal Data or Information (SPDI) under Indian law."]}]
27:["$","p",null,{"className":"text-gray-700 leading-relaxed mb-3","children":[["$","strong",null,{"children":"2.4 Payment data:"}]," subscription billing information processed via PCI-DSS compliant payment gateways (Razorpay, Stripe, SMEPay). We do ",["$","em",null,{"children":"not"}]," store full card numbers or CVV on our servers."]}]
28:["$","p",null,{"className":"text-gray-700 leading-relaxed mb-6","children":[["$","strong",null,{"children":"2.5 Technical data:"}]," IP address, device identifiers, browser type, operating system, app version, crash logs, and usage analytics."]}]
29:["$","h2",null,{"className":"text-2xl font-black text-gray-900 mt-8 mb-3","children":"3. Purpose of Collection"}]
2a:["$","ul",null,{"className":"list-disc pl-6 text-gray-700 space-y-2 mb-6","children":[["$","li",null,{"children":"To provide, maintain and improve the Service including billing, accounting and compliance features."}],["$","li",null,{"children":"To generate GST-compliant invoices, reports and filings on your behalf."}],["$","li",null,{"children":"To authenticate users and protect against fraud and unauthorised access."}],["$","li",null,{"children":"To communicate service updates, security alerts and billing notifications."}],["$","li",null,{"children":"To comply with legal, tax and regulatory obligations in India."}],["$","li",null,{"children":"To deliver customer support and resolve disputes."}]]}]
2b:["$","h2",null,{"className":"text-2xl font-black text-gray-900 mt-8 mb-3","children":"4. Legal Basis for Processing"}]
2c:["$","p",null,{"className":"text-gray-700 leading-relaxed mb-6","children":"We process personal data on the basis of (a) your consent at account creation, (b) performance of our contract with you, (c) compliance with legal obligations (including GST, income tax and IT Act requirements), and (d) legitimate business interests such as securing the platform and preventing misuse."}]
2d:["$","h2",null,{"className":"text-2xl font-black text-gray-900 mt-8 mb-3","children":"5. Third-Party Sharing & Sub-Processors"}]
2e:["$","p",null,{"className":"text-gray-700 leading-relaxed mb-3","children":"We do not sell your personal data. We share data only with the following categories of recipients, under contractual confidentiality:"}]
2f:["$","ul",null,{"className":"list-disc pl-6 text-gray-700 space-y-2 mb-6","children":[["$","li",null,{"children":[["$","strong",null,{"children":"Infrastructure providers:"}]," Supabase, AWS / GCP data centres located in India or regions offering equivalent safeguards."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Payment processors:"}]," Razorpay, Stripe, SMEPay for subscription collection."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Analytics & monitoring:"}]," Sentry for error tracking, Google Analytics for aggregate usage (anonymised)."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Government authorities:"}]," GSTN, income tax department, or law-enforcement agencies where legally compelled."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Professional advisors:"}]," auditors, lawyers and compliance consultants under strict confidentiality."]}]]}]
30:["$","h2",null,{"className":"text-2xl font-black text-gray-900 mt-8 mb-3","children":"6. Data Retention"}]
31:["$","p",null,{"className":"text-gray-700 leading-relaxed mb-6","children":["We retain your business and financial data for as long as your account is active and thereafter for a minimum of",["$","strong",null,{"children":" eight (8) years"}]," from the end of the relevant financial year, as required by Section 36 of the CGST Act, 2017 and Section 44AA of the Income Tax Act, 1961. Upon account closure, you may request export or deletion subject to these statutory retention obligations."]}]
32:["$","h2",null,{"className":"text-2xl font-black text-gray-900 mt-8 mb-3","children":"7. Data Security"}]
33:["$","p",null,{"className":"text-gray-700 leading-relaxed mb-6","children":"We implement reasonable security practices aligned with ISO/IEC 27001 and Rule 8 of the SPDI Rules, 2011, including TLS 1.2+ encryption in transit, AES-256 encryption at rest, role-based access control, row-level security, audit logging, regular penetration testing, and encrypted off-site backups. No method of electronic storage is 100% secure; we therefore cannot guarantee absolute security."}]
34:["$","h2",null,{"className":"text-2xl font-black text-gray-900 mt-8 mb-3","children":"8. Your Rights"}]
35:["$","p",null,{"className":"text-gray-700 leading-relaxed mb-3","children":"Subject to the DPDP Act, 2023 and applicable law, you have the right to:"}]
36:["$","ul",null,{"className":"list-disc pl-6 text-gray-700 space-y-2 mb-6","children":[["$","li",null,{"children":"Access and obtain a copy of the personal data we hold about you."}],["$","li",null,{"children":"Correct or update inaccurate or incomplete data."}],["$","li",null,{"children":"Withdraw consent (where processing is based on consent)."}],["$","li",null,{"children":"Request erasure, subject to statutory retention requirements."}],["$","li",null,{"children":"Nominate another individual to exercise your rights in the event of death or incapacity."}],["$","li",null,{"children":"Lodge a grievance with our Grievance Officer (see Section 12) or the Data Protection Board of India."}]]}]
37:["$","h2",null,{"className":"text-2xl font-black text-gray-900 mt-8 mb-3","children":"9. Cookies & Tracking"}]
38:["$","p",null,{"className":"text-gray-700 leading-relaxed mb-6","children":"We use strictly-necessary cookies for authentication and session management, and analytics cookies (with your consent) to understand aggregate usage. You can control cookies through your browser settings. Disabling strictly-necessary cookies may impair your ability to sign in and use the Service."}]
39:["$","h2",null,{"className":"text-2xl font-black text-gray-900 mt-8 mb-3","children":"10. Cross-Border Transfers"}]
3a:["$","p",null,{"className":"text-gray-700 leading-relaxed mb-6","children":"Primary data storage is within India. Where limited processing occurs outside India (e.g. global CDN, payment gateways), we rely on contractual safeguards and jurisdictions that ensure an adequate level of protection, as notified by the Central Government under Section 16 of the DPDP Act."}]
3b:["$","h2",null,{"className":"text-2xl font-black text-gray-900 mt-8 mb-3","children":"11. Children"}]
3c:["$","p",null,{"className":"text-gray-700 leading-relaxed mb-6","children":"The Service is intended for businesses and individuals aged 18 or above. We do not knowingly collect personal data from children under 18. If you believe we have done so, please contact us and we will delete such data promptly."}]
3d:["$","h2",null,{"className":"text-2xl font-black text-gray-900 mt-8 mb-3","children":"12. Grievance Officer & Contact"}]
3e:["$","p",null,{"className":"text-gray-700 leading-relaxed mb-3","children":"In accordance with Rule 5(9) of the SPDI Rules, 2011 and Section 10 of the IT (Intermediary Guidelines) Rules, 2021:"}]
3f:["$","div",null,{"className":"bg-emerald-50 border border-emerald-100 rounded-2xl p-5 mb-6","children":[["$","p",null,{"className":"text-gray-800 font-bold mb-1","children":"Grievance Officer"}],["$","p",null,{"className":"text-gray-700 text-sm","children":["MandiGrow",["$","br",null,{}],"Email: ",["$","a",null,{"href":"mailto:privacy@mandigrow.com","className":"text-emerald-700 font-bold","children":"privacy@mandigrow.com"}],["$","br",null,{}],"Support: ",["$","a",null,{"href":"mailto:support@mandigrow.com","className":"text-emerald-700 font-bold","children":"support@mandigrow.com"}],["$","br",null,{}],"Response time: within 15 days of receipt of a valid request."]}]]}]
40:["$","h2",null,{"className":"text-2xl font-black text-gray-900 mt-8 mb-3","children":"13. Changes to this Policy"}]
41:["$","p",null,{"className":"text-gray-700 leading-relaxed mb-0","children":"We may update this Privacy Policy from time to time. Material changes will be notified by email or in-app notice at least 7 days before they take effect. Your continued use of the Service after the effective date constitutes acceptance of the revised Policy."}]
